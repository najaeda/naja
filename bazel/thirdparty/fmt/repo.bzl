"""Repository rule wrapping the system-installed fmt library, located via
pkg-config -- the same fmt that slang's own CMake build finds via
`find_package(fmt)` (thirdparty/slang/external/CMakeLists.txt, fed
through CMAKE_PREFIX_PATH by bazel/thirdparty/slang/host_prefixes.bzl).

svlang's own static library only contains slang's *own* object files;
since fmt was linked as an external system library rather than bundled
in by CMake's FetchContent fallback, downstream consumers (like
@slang//:slang, task #14) need to link against it directly too. Mirrors
the same pkg-config wrapping pattern as bazel/thirdparty/tbb/repo.bzl.

Exposes `@fmt//:fmt`.
"""

_BUILD_TEMPLATE = """\
# Generated by bazel/thirdparty/fmt/repo.bzl -- do not edit.
package(default_visibility = ["//visibility:public"])

cc_library(
    name = "fmt",
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    linkopts = ["-L{libdir}", "-lfmt"],
)
"""

def _fmt_repository_impl(repository_ctx):
    pkgconfig = repository_ctx.which("pkg-config")
    if not pkgconfig:
        fail("pkg-config not found on PATH; required to locate the system " +
             "fmt installation for the @fmt Bazel repository.")

    def pkgconfig_var(var):
        result = repository_ctx.execute([pkgconfig, "--variable=" + var, "fmt"])
        if result.return_code != 0 or not result.stdout.strip():
            fail("pkg-config --variable={} fmt failed (rc={}): {}\n".format(
                var,
                result.return_code,
                result.stderr,
            ) + "Is fmt installed? (brew install fmt / apt install libfmt-dev)")
        return result.stdout.strip()

    includedir = pkgconfig_var("includedir")
    libdir = pkgconfig_var("libdir")

    repository_ctx.symlink(includedir, "include")
    repository_ctx.file(
        "BUILD.bazel",
        _BUILD_TEMPLATE.format(libdir = libdir),
    )

fmt_repository = repository_rule(
    implementation = _fmt_repository_impl,
    local = True,
    doc = "Wraps the system-installed fmt, located via pkg-config.",
)
