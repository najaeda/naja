"""Repository rule wrapping the system-installed tomlplusplus library,
located via pkg-config -- the same one slang's own CMake build finds via
`find_package(tomlplusplus)` (thirdparty/slang/external/CMakeLists.txt,
fed through CMAKE_PREFIX_PATH by bazel/thirdparty/slang/host_prefixes.bzl).

Same situation as bazel/thirdparty/fmt/repo.bzl: svlang's static library
doesn't bundle it in (found as an external system lib, not vendored via
FetchContent), so `@slang//:slang` (task #14) needs to link it directly
too -- surfaced by an undefined-symbol link error in
`slang::WaiverManager` when a real consumer (naja_snl_systemverilog,
task #17) was actually linked into a binary.

Exposes `@tomlplusplus//:tomlplusplus`.
"""

_BUILD_TEMPLATE = """\
# Generated by bazel/thirdparty/tomlplusplus/repo.bzl -- do not edit.
package(default_visibility = ["//visibility:public"])

cc_library(
    name = "tomlplusplus",
    hdrs = glob(["include/**/*.h", "include/**/*.hpp"]),
    includes = ["include"],
    defines = {defines},
    linkopts = ["-L{libdir}", "-ltomlplusplus"],
)
"""

def _tomlplusplus_repository_impl(repository_ctx):
    pkgconfig = repository_ctx.which("pkg-config")
    if not pkgconfig:
        fail("pkg-config not found on PATH; required to locate the system " +
             "tomlplusplus installation for the @tomlplusplus Bazel repository.")

    def pkgconfig_var(var):
        result = repository_ctx.execute([pkgconfig, "--variable=" + var, "tomlplusplus"])
        if result.return_code != 0 or not result.stdout.strip():
            fail("pkg-config --variable={} tomlplusplus failed (rc={}): {}\n".format(
                var,
                result.return_code,
                result.stderr,
            ) + "Is tomlplusplus installed? (brew install tomlplusplus / apt install libtomlplusplus-dev)")
        return result.stdout.strip()

    def pkgconfig_defines():
        result = repository_ctx.execute([pkgconfig, "--cflags-only-other", "tomlplusplus"])
        if result.return_code != 0:
            fail("pkg-config --cflags-only-other tomlplusplus failed: " + result.stderr)
        defines = []
        for flag in result.stdout.strip().split(" "):
            if flag.startswith("-D"):
                defines.append(flag[2:])
        return defines

    includedir = pkgconfig_var("includedir")
    libdir = pkgconfig_var("libdir")
    defines = pkgconfig_defines()

    repository_ctx.symlink(includedir, "include")
    repository_ctx.file(
        "BUILD.bazel",
        _BUILD_TEMPLATE.format(libdir = libdir, defines = repr(defines)),
    )

tomlplusplus_repository = repository_rule(
    implementation = _tomlplusplus_repository_impl,
    local = True,
    doc = "Wraps the system-installed tomlplusplus, located via pkg-config.",
)
