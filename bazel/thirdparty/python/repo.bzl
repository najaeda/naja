"""Repository rule wrapping the system-installed Python 3, located via
`python3-config` -- the same interpreter CMake's `find_package(Python
REQUIRED COMPONENTS Interpreter Development.Module)` /
`Development.Embed` (CMakeLists.txt) resolves against. Mirrors the
pragmatic system-wrapping pattern this migration already uses throughout
(TBB/Boost/fmt/tomlplusplus in bazel/thirdparty/, bison/m4 in
bazel/system_tool.bzl) rather than pulling in rules_python's hermetic
toolchain -- naja's own CMake build already just uses whatever Python 3
is on the system, so this matches that exactly instead of introducing a
second, different Python for Bazel builds.

Exposes:
  - `@python//:headers` -- Python.h only, no linking. Correct for
    building a Python *extension module* (naja.so): on both macOS and
    Linux, extension module symbols are resolved dynamically by the
    interpreter at import time, not linked at build time (matches
    CMake's `Python3::Module` -- see src/nl/python/naja_wrapping/CMakeLists.txt).
  - `@python//:embed` -- headers + linking the full libpython. Correct
    for *embedding* an interpreter (matches CMake's `Python3::Python`),
    needed by naja_edit's embedded-Python mode (task #22).
"""

def _python_repository_impl(repository_ctx):
    python_config = repository_ctx.which("python3-config")
    if not python_config:
        fail("python3-config not found on PATH; required to locate the " +
             "system Python 3 installation for the @python Bazel repository.")

    def run(args):
        result = repository_ctx.execute([python_config] + args)
        if result.return_code != 0:
            fail("{} {} failed (rc={}): {}".format(
                python_config,
                " ".join(args),
                result.return_code,
                result.stderr,
            ))
        return result.stdout.strip()

    includes = run(["--includes"]).split(" ")
    include_dirs = [f[2:] for f in includes if f.startswith("-I")]
    if not include_dirs:
        fail("python3-config --includes returned no -I flags: {}".format(includes))

    for i, d in enumerate(include_dirs):
        repository_ctx.symlink(d, "include{}".format(i))

    embed_ldflags = run(["--ldflags", "--embed"]).split(" ")
    embed_libdirs = [f[2:] for f in embed_ldflags if f.startswith("-L")]
    embed_libs = [f[2:] for f in embed_ldflags if f.startswith("-l")]
    embed_other = [f for f in embed_ldflags if f and not f.startswith(("-L", "-l"))]

    include_attr = "[{}]".format(", ".join(
        ['"include{}"'.format(i) for i in range(len(include_dirs))]
    ))
    headers_glob = "[{}]".format(", ".join(
        ['"include{}/**/*.h"'.format(i) for i in range(len(include_dirs))]
    ))

    embed_linkopts = ["-L" + d for d in embed_libdirs] + \
                      ["-l" + l for l in embed_libs] + \
                      embed_other

    repository_ctx.file(
        "BUILD.bazel",
        """\
# Generated by bazel/thirdparty/python/repo.bzl -- do not edit.
package(default_visibility = ["//visibility:public"])

cc_library(
    name = "headers",
    hdrs = glob({headers_glob}),
    includes = {include_attr},
)

cc_library(
    name = "embed",
    hdrs = glob({headers_glob}),
    includes = {include_attr},
    linkopts = {embed_linkopts},
)
""".format(
            headers_glob = headers_glob,
            include_attr = include_attr,
            embed_linkopts = repr(embed_linkopts),
        ),
    )

python_repository = repository_rule(
    implementation = _python_repository_impl,
    local = True,
    doc = "Wraps the system-installed Python 3, located via python3-config.",
)
