"""Repository rule wrapping the system-installed oneTBB (TBB has no Bazel
Central Registry module). Locates the existing installation via
pkg-config -- the same TBB that CMake's `find_package(TBB REQUIRED)`
(CMakeLists.txt:121) resolves against, installed by `brew install tbb` on
macOS or the `libtbb-dev` apt package on Linux (see the Phase 0 CI
dependency matrix in internal/bazel-migration-plan.md). This wraps the
prebuilt system library rather than building oneTBB from source under
Bazel, matching how naja already consumes it via CMake.

Exposes `@tbb//:tbb` and `@tbb//:tbbmalloc`, mirroring the `TBB::tbb` and
`TBB::tbbmalloc` CMake targets linked by src/dnl/CMakeLists.txt.
"""

_BUILD_TEMPLATE = """\
# Generated by bazel/thirdparty/tbb/repo.bzl -- do not edit.
package(default_visibility = ["//visibility:public"])

cc_library(
    name = "tbb",
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    linkopts = ["-L{libdir}", "-ltbb"],
)

cc_library(
    name = "tbbmalloc",
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    linkopts = ["-L{libdir}", "-ltbbmalloc"],
)
"""

def _tbb_repository_impl(repository_ctx):
    pkgconfig = repository_ctx.which("pkg-config")
    if not pkgconfig:
        fail("pkg-config not found on PATH; required to locate the system " +
             "TBB (oneTBB) installation for the @tbb Bazel repository.")

    def pkgconfig_var(var):
        result = repository_ctx.execute([pkgconfig, "--variable=" + var, "tbb"])
        if result.return_code != 0 or not result.stdout.strip():
            fail("pkg-config --variable={} tbb failed (rc={}): {}\n".format(
                var,
                result.return_code,
                result.stderr,
            ) + "Is TBB installed? (brew install tbb / apt install libtbb-dev)")
        return result.stdout.strip()

    includedir = pkgconfig_var("includedir")
    libdir = pkgconfig_var("libdir")

    repository_ctx.symlink(includedir, "include")
    repository_ctx.file(
        "BUILD.bazel",
        _BUILD_TEMPLATE.format(libdir = libdir),
    )

tbb_repository = repository_rule(
    implementation = _tbb_repository_impl,
    local = True,
    doc = "Wraps the system-installed oneTBB, located via pkg-config.",
)
