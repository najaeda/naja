"""Repository rule wrapping the system-installed Boost (no Bazel Central
Registry module covers the plain header-only usage naja needs). naja only
ever consumes Boost as headers -- every src/*/CMakeLists.txt that touches
Boost does so via `target_include_directories(... ${Boost_INCLUDE_DIR})`
only, never a compiled Boost:: component library (see the grep audit
recorded for task #11 in internal/bazel-migration-plan.md) -- matching
CMakeLists.txt:117's own `find_path(Boost_INCLUDE_DIR NAMES
boost/version.hpp)` search.

Boost (unlike TBB) generally ships no pkg-config file, so this searches
the same common install prefixes CMake's FindBoost would, honoring
BOOST_INCLUDEDIR/BOOST_ROOT overrides first.

Exposes `@boost//:headers`, a header-only cc_library.
"""

_CANDIDATE_INCLUDE_DIRS = [
    "/opt/homebrew/include",  # Homebrew, Apple Silicon
    "/usr/local/include",  # Homebrew, Intel mac / local Linux installs
    "/usr/include",  # Linux libboost-dev (apt)
]

_BUILD_TEMPLATE = """\
# Generated by bazel/thirdparty/boost/repo.bzl -- do not edit.
package(default_visibility = ["//visibility:public"])

cc_library(
    name = "headers",
    hdrs = glob(["include/boost/**"]),
    includes = ["include"],
)
"""

def _boost_repository_impl(repository_ctx):
    env_dir = (repository_ctx.os.environ.get("BOOST_INCLUDEDIR") or
               repository_ctx.os.environ.get("BOOST_ROOT"))
    candidates = ([env_dir] if env_dir else []) + _CANDIDATE_INCLUDE_DIRS

    found = None
    for candidate in candidates:
        if candidate and repository_ctx.path(candidate + "/boost/version.hpp").exists:
            found = candidate
            break

    if not found:
        fail(("Could not locate a Boost installation (boost/version.hpp) " +
              "in any of: {}. Set BOOST_INCLUDEDIR (or BOOST_ROOT) to " +
              "override. Is Boost installed? (brew install boost / apt " +
              "install libboost-dev)").format(candidates))

    repository_ctx.symlink(found, "include")
    repository_ctx.file("BUILD.bazel", _BUILD_TEMPLATE)

boost_repository = repository_rule(
    implementation = _boost_repository_impl,
    local = True,
    environ = ["BOOST_INCLUDEDIR", "BOOST_ROOT"],
    doc = "Wraps the system-installed Boost headers.",
)
