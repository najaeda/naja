# SNLLibertyConstructorTest1.cpp's testBundleTermsIssue120VerilogIntegration
# also reaches across to ../verilog/benchmarks (a relative path from
# CMAKE_CURRENT_SOURCE_DIR in CMake) -- needs that filegroup as data too.
cc_test(
    name = "snl_liberty_tests",
    srcs = [
        "SNLLibertyConstructorTest0.cpp",
        "SNLLibertyConstructorTest1.cpp",
        "SNLLibertyConstructorTest2.cpp",
        "SNLLibertyConstructorZlibTest.cpp",
        "SNLBooleanTreeTest0.cpp",
        "SNLBooleanTreeTest1.cpp",
    ],
    data = glob(["benchmarks/**"]) + ["//test/nl/formats/verilog:benchmarks"],
    defines = ['SNL_LIBERTY_BENCHMARKS=\\"test/nl/formats/liberty\\"'],
    deps = [
        "//src/nl/formats/liberty:naja_snl_liberty",
        "//src/nl/formats/verilog:naja_snl_verilog",
        "//src/nl/netlist/serialization/capnp:naja_nl_dump",
        "@googletest//:gtest_main",
        "@zlib//:zlib",
    ],
)
