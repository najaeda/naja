# Exposes benchmarks/ as data for test/nl/formats/{verilog,systemverilog}
# (both reference it as "../benchmarks" from CMAKE_CURRENT_SOURCE_DIR).

filegroup(
    name = "benchmarks",
    srcs = glob(["benchmarks/**"], exclude = ["benchmarks/__pycache__/**"]),
    visibility = ["//test:__subpackages__"],
)
