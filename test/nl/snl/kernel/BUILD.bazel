cc_test(
    name = "snlTests",
    # 190 actual TEST_F/TEST cases -- capped at 50, Bazel's hard
    # shard_count ceiling, so under --define=isolated_tests=true this gets
    # ~3.8 tests/process on average rather than true 1:1 isolation.
    shard_count = select({
        "//bazel:isolated_tests": 50,
        "//conditions:default": 1,
    }),
    srcs = [
        "NLIDTest.cpp",
        "NLNameTest.cpp",
        "NLUniverseTest.cpp",
        "NLDBTest.cpp",
        "NLLibraryTest.cpp",
        "NLDB0Test.cpp",
        "SNLDesignTest.cpp",
        "SNLDesignCloneTest.cpp",
        "SNLBundleTermTest.cpp",
        "SNLTermTest.cpp",
        "SNLInstanceTest0.cpp",
        "SNLInstanceTest1.cpp",
        "SNLInstanceTest2.cpp",
        "SNLInstanceTest3.cpp",
        "SNLInstanceSetModelTest.cpp",
        "SNLNetTest.cpp",
        "SNLPathTest0.cpp",
        "SNLPathTest1.cpp",
        "SNLPathTest2.cpp",
        "SNLOccurrenceTest.cpp",
        "SNLParameterTest.cpp",
        "SNLAttributesTest.cpp",
        "SNLRTLInfosTest.cpp",
        "SNLMergeAssignsTest.cpp",
        "SNLUtilsTest.cpp",
    ],
    deps = [
        "//src/nl/netlist:naja_nl",
        "@googletest//:gtest_main",
    ],
)

# snlTestsWithPyLoader (SNLEquipotentialTest0/1.cpp) is deferred: its
# benchs/*.py scripts `import naja` and are exec'd by the embedded
# interpreter via SNLPyLoader, meaning naja.so (a *separate* dlopen'd
# shared object) and this test binary would each carry their own
# independently-static-linked copy of naja_nl's NLUniverse singleton --
# see internal/bazel-migration-plan.md's task #21/#22 "static vs shared
# linking" finding for the full explanation and why it's not fixed here.
