cc_test(
    name = "snlDecoratorsTests",
    # 93 actual TEST_F/TEST cases -- capped at 50, Bazel's hard shard_count
    # ceiling, so under --define=isolated_tests=true this gets ~1.9
    # tests/process on average rather than true 1:1 isolation.
    shard_count = select({
        "//bazel:isolated_tests": 50,
        "//conditions:default": 1,
    }),
    srcs = [
        "SNLDesignModelingTest0.cpp",
        "SNLTruthTableTest.cpp",
        "SNLDesignTruthTablesTest0.cpp",
        "SNLDesignTruthTablesTest1.cpp",
        "SNLLibraryTruthTablesTest.cpp",
        "SNLGateTruthTablesTest.cpp",
    ],
    deps = [
        "//src/nl/netlist:naja_nl",
        "@googletest//:gtest_main",
    ],
)
