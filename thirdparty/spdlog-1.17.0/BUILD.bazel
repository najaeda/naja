# Vendored directly in this repo (not a submodule). naja only ever uses
# it header-only (CMakeLists.txt:67 sets SPDLOG_DIR to this include/ dir
# as a plain include path, no compiled spdlog sources are added to any
# target), so this is just a header-only cc_library.

cc_library(
    name = "spdlog",
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    visibility = ["//visibility:public"],
)
