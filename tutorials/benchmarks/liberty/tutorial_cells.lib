 *
 * Minimal tutorial cell library — structural interface only (no timing/power data).
 * Cell names follow the NanGate 45nm Open Cell Library naming convention.
 * Pin names and directions are derived from tinyrocket.v, which is a derivative
 * of the RocketChip project (Apache 2.0, https://github.com/chipsalliance/rocket-chip).
 */
library (tutorial_cells) {
  technology (cmos);
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  capacitive_load_unit (1, ff);
  leakage_power_unit : "1nW";
  pulling_resistance_unit : "1kohm";
  delay_model : table_lookup;
  nom_process : 1;
  nom_temperature : 25;
  nom_voltage : 1.1;
  cell (AND2_X1) {
    pin (A1) { direction : input; }
    pin (A2) { direction : input; }
    pin (ZN) { direction : output; }
  }

